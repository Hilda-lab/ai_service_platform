APP_NAME=ai-service-platform
APP_ENV=dev
HTTP_PORT=8080

JWT_SECRET=replace-with-strong-secret
JWT_EXPIRE_HOURS=72

MYSQL_DSN=ai_user:ai_pass@tcp(127.0.0.1:3307)/ai_platform?charset=utf8mb4&parseTime=True&loc=Local
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672/

AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://cdn.12ai.org
OPENAI_MODEL=gpt-5.1
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1

GEMINI_API_KEY=
GEMINI_BASE_URL=https://cdn.12ai.org
GEMINI_MODEL=gemini-3-pro-preview

VISION_PROVIDER=openai
VISION_MODEL=gpt-4.1-mini
VISION_MOCK=false
VISION_QUEUE=vision_tasks

SPEECH_PROVIDER=openai
SPEECH_TTS_MODEL=gpt-4o-mini-tts
SPEECH_ASR_MODEL=whisper-1
SPEECH_VOICE=alloy
SPEECH_LANGUAGE=zh
SPEECH_MOCK=false

VECTOR_DB_URL=
TTS_PROVIDER=
ASR_PROVIDER=
